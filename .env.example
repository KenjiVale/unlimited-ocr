APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
OCR_MODEL_ID=baidu/Unlimited-OCR
OCR_MODEL_PATH=./data/models/Unlimited-OCR
OCR_DEVICE=cuda
OCR_DTYPE=bfloat16
OCR_DEFAULT_MODE=gundam
OCR_MAX_LENGTH=8192
OCR_CONCURRENCY=1
PDF_DEFAULT_DPI=200
PDF_MAX_PAGES=100
UPLOAD_MAX_MB=200
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/app.db
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
WORKER_POLL_INTERVAL_MS=500
WORKER_HEARTBEAT_INTERVAL_SECONDS=5
WORKER_STALE_AFTER_SECONDS=120
DATABASE_BUSY_TIMEOUT_MS=5000
DATABASE_JOURNAL_MODE=WAL
MAX_QUEUED_JOBS=50
MIN_FREE_DISK_GB=5
CLEANUP_ENABLED=false
CLEANUP_RETENTION_DAYS=30
CLEANUP_INCLUDE_RENDERED_PAGES=true
CLEANUP_INCLUDE_SOURCE_FILES=false
SHUTDOWN_GRACE_SECONDS=30
API_HEALTH_TARGET_MS=250
